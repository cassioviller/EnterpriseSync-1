modules = ["python-3.11", "python3", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["cairo", "cargo", "ffmpeg-full", "freetype", "ghostscript", "gitFull", "glibcLocales", "gobject-introspection", "gtk3", "lcms2", "libGL", "libGLU", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "pkg-config", "playwright-driver", "postgresql", "qhull", "rustc", "tcl", "tk", "xcodebuild", "zlib"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-agrupamento"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-orcamento-override"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-e2e-proposta-aprovacao-cliente"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-cronograma-duplicado-rdo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-rdo-unificado-responsaveis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-clausulas-configuraveis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-cronograma-revisao-obra-gate"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[workflows.workflow]]
name = "test-agrupamento"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_agrupamento_diarias_rdo.py"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-orcamento-override"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_orcamento_override_e2e.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-e2e-proposta-aprovacao-cliente"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_e2e_proposta_aprovacao_cliente.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-cronograma-duplicado-rdo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_cronograma_duplicado_rdo.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-rdo-unificado-responsaveis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_rdo_unificado_responsaveis.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-clausulas-configuraveis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_clausulas_configuraveis.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-cronograma-revisao-obra-gate"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/test_cronograma_revisao_obra_gate.py"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
integrations = ["python_database:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
